# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/employee_tracker?schema=public"

# JWT Secrets (generate each with: node -e "require('crypto').randomBytes(32).toString('hex')" )
JWT_SECRET="replace-with-256-bit-random-string"
COMPANY_JWT_SECRET="replace-with-different-256-bit-string"
ADMIN_JWT_SECRET="replace-with-another-different-256-bit-string"

# Server
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
COMPANY_PORTAL_URL=http://localhost:3001

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Email (Gmail: use App Password, not regular password)
# For SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=your_sendgrid_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Employee Monitor <your_email@gmail.com>

# Company Settings (used in email templates)
COMPANY_NAME=Your Company
DASHBOARD_URL=http://localhost:3000

# Agent Downloads
VPS_URL=http://localhost:5001

# Slack Integration (create a Slack app at https://api.slack.com/apps)
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=http://localhost:5001/api/slack/callback

# Encryption key for storing Slack bot tokens securely (generate with: node -e "require('crypto').randomBytes(32).toString('hex')")
SLACK_ENCRYPTION_KEY=replace_with_64_char_hex_string
